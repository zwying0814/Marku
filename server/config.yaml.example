# Marku 服务器配置文件

# 站点配置
site:
  # 系统运行端口
  port: 12123
  
  # 系统运行密钥
  app_key: "123456"
  
  # 日志文件路径
  log_path: "./data/log.txt"
  
  # 每次启动是否清空数据表
  drop_table: false
  
  # CORS 允许的域名列表
  allowed_origins:
    - "http://localhost:3000"
    - "http://localhost:5173"
    - "file://"

# 评论状态配置
comment:
  # 新评论默认状态，支持 pending / approved / rejected 等英文状态名
  default_status: "pending"

  # 评论是否需要登录后才能提交
  require_login: false

# SMTP 配置
smtp:
  # 是否启用邮件发送
  enabled: false
  # SMTP 服务器地址
  host: "smtp.example.com"
  # SMTP 端口
  port: 587
  # SMTP 用户名
  username: "user@example.com"
  # SMTP 密码
  password: "password"
  # 发件人地址
  from: "Marku <user@example.com>"
  # 发件人显示名
  sender_name: "Marku"
  # 安全模式: plain / starttls / ssl
  security: "starttls"
  # 是否跳过证书校验
  skip_verify: false

# 数据库配置
database:
  # 数据库类型: "sqlite" 或 "mysql"
  type: "sqlite"
  
  # SQLite 数据库配置
  sqlite:
    # 数据库文件路径
    path: "./data/marku.bin"
  
  # MySQL 数据库配置
  mysql:
    # 主机地址
    host: "localhost"
    # 端口号
    port: 3306
    # 用户名
    username: "marku"
    # 密码
    password: "password"
    # 数据库名
    database: "marku"
    # 字符集
    charset: "utf8mb4"

# 管理员配置
admin:
  # 管理员账户
  username: "admin"
  
  # 管理员密码
  password: "123456"
  
  # 管理员邮箱
  email: "example@admin.com"