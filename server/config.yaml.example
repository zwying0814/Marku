# Marku 服务器配置文件

# 站点配置
site:
  # 系统运行端口
  port: 12123
  
  # 系统运行密钥
  app_key: "123456"
  
  # 日志文件路径
  log_path: "./data/log.txt"
  
  # 每次启动是否清空数据表
  drop_table: false
  
  # CORS 允许的域名列表
  allowed_origins:
    - "http://localhost:3000"
    - "http://localhost:5173"
    - "file://"

# 数据库配置
database:
  # 数据库类型: "sqlite" 或 "mysql"
  type: "sqlite"
  
  # SQLite 数据库配置
  sqlite:
    # 数据库文件路径
    path: "./data/marku.bin"
  
  # MySQL 数据库配置
  mysql:
    # 主机地址
    host: "localhost"
    # 端口号
    port: 3306
    # 用户名
    username: "marku"
    # 密码
    password: "password"
    # 数据库名
    database: "marku"
    # 字符集
    charset: "utf8mb4"

# 管理员配置
admin:
  # 管理员账户
  username: "admin"
  
  # 管理员密码
  password: "123456"
  
  # 管理员邮箱
  email: "example@admin.com"